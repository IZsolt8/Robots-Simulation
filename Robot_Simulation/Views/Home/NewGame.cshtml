@model Robot_Simulation.Models.Game

@{
    ViewData["Title"] = "Create";
}

<style>
    .header {
        text-align: center;
    }

    .create_container {
        display: flex;
        justify-content: center;
        padding-top: 20px;
    }

    .input_buttons_container {
        width: 100%;
        max-width: 400px;
    }

    .input {
        margin-bottom: 30px;
    }

    .buttons {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
</style>

<div class="header">
    <h1>Játék Létrehozása</h1>
</div>
<hr />

<div class="create_container">
    <div class="input_buttons_container">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group input">
                <label asp-for="GameName" class="control-label"></label>
                <input asp-for="GameName" class="form-control" />
                <span asp-validation-for="GameName" class="text-danger"></span>
            </div>
            <div class="buttons">
                <a asp-action="Index" class="btn btn-secondary">Vissza</a>
                <input type="submit" value="Létrehozás" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}