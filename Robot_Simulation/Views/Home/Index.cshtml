@{
    ViewData["Title"] = "Menu";
}

<style>
    .menu_container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 100px);
        font-family: Arial, sans-serif;
        background-color: transparent;
    }

    .buttons_div {
        display: flex;
        flex-direction: column;
        gap: 30px;
        width: 350px;
    }

    .buttons {
        padding: clamp(15px, 2.5vh, 40px);
        text-align: center;
        font-size: clamp(18px, 2vw, 36px);
        border-radius: 8px;
        text-decoration: none;
        color: black;
        border: 1px solid;
        display: block;
        background-color: #d5d5d5;
        border-color: Black;
    }
    
        .buttons:hover {
            filter: brightness(0.95);
            color: black
        }
</style>

<div class="menu_container">
    <div class="buttons_div">
        <a asp-action="NewGame" class="buttons">Új játék</a>
        <a asp-action="LoadGame" class="buttons">Játék betöltése</a>
        <a asp-action="Exit" class="buttons">Kilépés</a>
    </div>
</div>